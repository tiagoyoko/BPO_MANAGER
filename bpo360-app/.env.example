# Supabase (copie de Project Settings → API no painel Supabase)
# NUNCA commitar valores reais; use .env.local para desenvolvimento.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role (obrigatório para admin/usuarios – criar usuários no Auth). NUNCA expor no client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Opcional: senha do DB apenas se usar migrações locais com Supabase CLI.
# DATABASE_PASSWORD=your-db-password

# Chave de criptografia para tokens F360 (32 bytes como 64 hex chars). Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# ===== Test framework =====
# Ambiente lógico para testes (local, ci, staging, etc.)
TEST_ENV=local

# Base URL usada pelos testes E2E (Playwright)
BASE_URL=http://localhost:3000

